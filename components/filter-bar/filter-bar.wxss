.filter-bar {
  background: var(--white);
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.quick-filters {
  white-space: nowrap;
  height: 56rpx;
}

.quick-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  background: var(--gray-100);
  color: var(--gray-700);
  white-space: nowrap;
  transition: all 0.2s;
}

.quick-tag.active {
  background: var(--green-800);
  color: var(--white);
}

.quick-tag.more {
  background: var(--white);
  border: 1rpx solid var(--gray-300);
}

.quick-tag.more.active {
  background: var(--green-100);
  border-color: var(--green-600);
  color: var(--green-800);
}

/* 展开面板 */
.filter-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.filter-panel.show {
  max-height: 600rpx;
  padding-top: 20rpx;
}

.panel-title {
  margin-top: 8rpx;
}

.panel-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: var(--gray-100);
  color: var(--gray-700);
}

.panel-tag.active {
  background: var(--green-50);
  color: var(--green-800);
  border: 1rpx solid var(--green-600);
}

.panel-actions {
  padding-top: 8rpx;
}

.btn-reset, .btn-confirm {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

.btn-reset {
  background: var(--gray-100);
  color: var(--gray-700);
}

.btn-confirm {
  background: var(--green-800);
  color: var(--white);
}
