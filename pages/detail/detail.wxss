.detail-header {
  margin: 16rpx 24rpx;
}

/* 核心指标网格 */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 24rpx 16rpx;
  gap: 16rpx;
}

.metric-box {
  flex: 1;
  min-width: calc(50% - 24rpx);
  background: var(--white);
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: var(--shadow);
}

.metric-num {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  line-height: 1.2;
}

.metric-title {
  font-size: 24rpx;
  color: var(--gray-500);
  margin-top: 8rpx;
  display: block;
}

/* 详细信息 */
.detail-section {
  margin: 0 24rpx 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gray-900);
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--gray-200);
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--gray-500);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--gray-900);
  line-height: 1.5;
}

/* 时间线 */
.timeline {
  padding-left: 16rpx;
}

.timeline-item {
  display: flex;
  padding-bottom: 24rpx;
  position: relative;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 24rpx;
  bottom: 0;
  width: 2rpx;
  background: var(--gray-200);
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: var(--gray-300);
  flex-shrink: 0;
  margin-top: 4rpx;
}

.timeline-dot.active {
  background: var(--green-600);
  box-shadow: 0 0 0 6rpx var(--green-100);
}

.timeline-content {
  flex: 1;
  margin-left: 16rpx;
}

.timeline-action {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-900);
  display: block;
}

.timeline-date {
  display: block;
  margin-top: 4rpx;
}

.timeline-remark {
  display: block;
  margin-top: 4rpx;
}

/* 来源 */
.source-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}

.source-item:last-child {
  border-bottom: none;
}
