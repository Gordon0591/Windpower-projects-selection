.search-header {
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-box {
  background: var(--gray-100);
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}

.search-icon-text {
  font-size: 28rpx;
}

.search-field {
  font-size: 28rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.search-btn {
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 历史 */
.history-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  background: var(--gray-100);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--gray-700);
}

.empty-state {
  padding: 120rpx 48rpx;
}
