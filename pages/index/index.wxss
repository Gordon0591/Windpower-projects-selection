/* 搜索栏 */
.search-bar {
  background: var(--white);
  padding: 16rpx 24rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: var(--gray-100);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-placeholder {
  color: var(--gray-400);
  font-size: 28rpx;
}

/* 列表 */
.list-header {
  padding-top: 8rpx;
}

.load-more {
  padding: 24rpx;
}

.empty-state {
  padding: 120rpx 48rpx;
}
